{
  "name": "visionias-scraper",
  "version": "1.0.0",
  "description": "VisionIAS Current Affairs Scraper with HTML formatting and Supabase integration",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "run-once": "ts-node scripts/run-once.ts",
    "test-run": "ts-node src/index.ts --test",
    "build": "tsc"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.42.5",
    "axios": "^1.6.8",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "google-translate-api-next": "^0.1.0",
    "html-entities": "^2.5.2",
    "node-cron": "^3.0.3",
    "p-limit": "^3.1.0",
    "p-retry": "^4.6.2",
    "playwright": "^1.58.2",
    "slugify": "^1.6.6",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
